QWEN_API_KEY=replace_with_your_qwen_or_dashscope_key
DASHSCOPE_API_KEY=replace_with_your_dashscope_key
QWEN_MODEL=qwen-plus
QWEN_CHAT_MODEL=qwen-plus
QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Server-only Alibaba ECS backend URL for the Vercel same-origin proxy.
# Keep this non-VITE in production so browsers do not call HTTP from HTTPS.
MEDSBUDDY_API_BASE_URL=http://47.88.54.108
# Optional browser-visible backend URL. Use only for local HTTP dev or an HTTPS backend domain.
VITE_MEDSBUDDY_API_BASE_URL=
# Optional ElevenLabs voice support for speech-to-text and text-to-speech.
ELEVENLABS_API_KEY=
# FastAPI backend visit memory database.
DATABASE_PROVIDER=sqlite
DATABASE_URL=sqlite:///./medsbuddy.db
